# ── MongoDB Atlas ──
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=amf_metadata_fabric

# ── Atlas Admin API (Stream Processing & Index Management) ──
ATLAS_PUBLIC_KEY=<your-atlas-public-key>
ATLAS_PRIVATE_KEY=<your-atlas-private-key>
ATLAS_PROJECT_ID=<your-atlas-project-id>
ATLAS_CLUSTER_NAME=<your-cluster-name>
ATLAS_STREAM_INSTANCE=<your-stream-instance-name>

# ── Voyage AI (Embeddings) ──
VOYAGE_API_KEY=<your-voyage-api-key>
VOYAGE_MODEL=voyage-3.5

# ── Azure OpenAI (LLM) ──
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── LangSmith (Observability) ──
LANGSMITH_API_KEY=<your-langsmith-key>
LANGSMITH_PROJECT=amf-agent-demo
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
